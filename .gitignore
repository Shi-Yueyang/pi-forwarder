# pi_forwarder - Git ignore rules
# Generated to ignore build artifacts, IDE files, OS junk, and temporary files

## Build directories
/build/
/out/
/bin/
/lib/

## CMake artifacts
/CMakeFiles/
/cmake_install.cmake
/CMakeCache.txt
/GenerateCacheFiles/
/*.dir/
Makefile
## Visual Studio and MSBuild
/.vs/
*.vcxproj*
*.sln
*.suo
*.user
*.userosscache
*.VC.db
*.VC.VC.opendb

## Compiled object files, libs, and binaries
*.obj
*.o
*.lo
*.lai
*.la
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.out

## Debug files
*.pdb
*.debug

## Coverage and profiler
coverage/
*.gcno
*.gcda

## Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

## Logs
*.log

## IDEs
.vscode/
.idea/

## Python cache
__pycache__/
*.py[cod]

## macOS
.DS_Store

## Windows
Thumbs.db
ehthumbs.db
desktop.ini

## Backup files from editors
# Vim swap files
*.sw?
# Emacs
*~

## Third-party build outputs (if any)
third-party/**/build/

## Node/npm (if added later)
node_modules/
npm-debug.log*

## Misc
.cache/
.pytest_cache/

# Local config files
*.local
*.local.json

tests/integration/*.txt